# ─────────────────────────────────────────────────────────────
# camp-aneone (.env.example)
# Copy this file to .env and fill in your values.
# See docs/SETUP_ENV.md for step-by-step instructions.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
PUBLIC_URL=http://localhost:3000

# ── Auth (NextAuth v5) ────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Allowlist: only these emails can sign in (comma-separated)
ALLOWED_EMAILS=your-email@gmail.com

# Bearer token for system/admin API calls (webhooks, scripts)
# Generate with: openssl rand -base64 32
API_TOKEN=

# ── OAuth Token Encryption ───────────────────────────────────
# Encrypts stored OAuth tokens at rest (AES-256-GCM)
# REQUIRED in production. Generate with: openssl rand -base64 32
OAUTH_TOKEN_ENCRYPTION_KEY=

# ── Google OAuth + APIs ───────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Anthropic LLM ────────────────────────────────────────────
ANTHROPIC_API_KEY=
LLM_CLASSIFIER_MODEL=claude-3-5-haiku-20241022
LLM_SYNTHESIS_MODEL=claude-sonnet-4-20250514
LLM_MAX_RETRIES=3
LLM_TIMEOUT_MS=30000

# ── SQLite ────────────────────────────────────────────────────
DATABASE_PATH=./data/oneon.db

# ── Gmail Polling ─────────────────────────────────────────────
GMAIL_POLL_INTERVAL_MS=180000
GMAIL_MAX_RESULTS=20

# ── Google Calendar ───────────────────────────────────────────
CALENDAR_POLL_INTERVAL_MS=300000

# ── GitHub ────────────────────────────────────────────────────
# Fine-grained PAT from https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# ── Power Automate Bridges ────────────────────────────────────
# Shared secrets for validating inbound webhooks
# Generate each with: openssl rand -base64 32
PA_OUTLOOK_WEBHOOK_SECRET=
PA_TEAMS_WEBHOOK_SECRET=

# ── Cloudflare Tunnel ────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=

# ── Web Push (VAPID) ─────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@gmail.com

# ── Feature Flags ─────────────────────────────────────────────
# Set to "true" to enable, anything else (or missing) = disabled
FEATURE_AUTO_EXECUTE=false
FEATURE_PUSH_NOTIFICATIONS=false
FEATURE_CHAT=true
FEATURE_BACKGROUND_LOOP=false

# ── Processing Loop ──────────────────────────────────────────
PROCESSING_BATCH_SIZE=10
PROCESSING_INITIAL_BATCH_SIZE=3
PROCESSING_MAX_DURATION_MS=120000
PROCESSING_MAX_CONSECUTIVE_ERRORS=5
PROCESSING_BACKOFF_MULTIPLIER=2
PROCESSING_MAX_BACKOFF_MS=300000
LLM_DAILY_CALL_LIMIT=200

# ── Circuit Breaker (LLM) ────────────────────────────────────
CB_FAILURE_THRESHOLD=5
CB_RESET_TIMEOUT_MS=60000

# ── Logging ───────────────────────────────────────────────────
# Structured JSON to stdout (12-Factor)
LOG_LEVEL=info
