# Use npm-style flat node_modules layout (no virtual store, no symlinks).
# Required for Docker builds: pnpm's default isolated linker creates symlinks
# into the .pnpm virtual store; those symlinks break when the Docker layer
# containing the build stage is discarded between build and runtime stages.
# node-linker=hoisted installs packages directly into node_modules/ — identical
# to npm/yarn behaviour — and is pnpm's recommended mode for Docker/CI.
node-linker=hoisted
