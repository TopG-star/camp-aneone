# ─────────────────────────────────────────────────────────────
# .env.template — Production / staging secrets
# Copy to .env, fill in values, NEVER commit .env
# See docs/SETUP_ENV.md for instructions.
# ─────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=4000
PUBLIC_URL=https://your-domain.com

# ── Auth ─────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://your-domain.com
ALLOWED_EMAILS=
API_TOKEN=

# ── OAuth Token Encryption (REQUIRED in production) ──────────
# Generate: openssl rand -base64 32
OAUTH_TOKEN_ENCRYPTION_KEY=

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Anthropic LLM ───────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Database ─────────────────────────────────────────────────
DATABASE_PATH=./data/oneon.db

# ── GitHub ───────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# ── Power Automate Webhooks ──────────────────────────────────
PA_OUTLOOK_WEBHOOK_SECRET=
PA_TEAMS_WEBHOOK_SECRET=

# ── Cloudflare Tunnel ───────────────────────────────────────
# Quick Tunnel (free, no domain needed): leave blank — URL auto-assigned
# Named Tunnel (custom domain): uncomment and set token
# CLOUDFLARE_TUNNEL_TOKEN=

# ── Web Push (VAPID) ────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@example.com

# ── Feature Flags ────────────────────────────────────────────
FEATURE_AUTO_EXECUTE=false
FEATURE_PUSH_NOTIFICATIONS=false
FEATURE_CHAT=true
FEATURE_BACKGROUND_LOOP=true

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
